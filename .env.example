# KiroHub 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== 镜像配置 ====================
DOCKER_REGISTRY=docker.io
IMAGE_OWNER=terrysiu
IMAGE_TAG=latest

# ==================== 端口配置 ====================
WEB_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

# ==================== 数据库配置 ====================
POSTGRES_USER=kirohub
POSTGRES_PASSWORD=please-change-me
POSTGRES_DB=kirohub

# ==================== 安全密钥（必须配置）====================
# JWT 签名密钥（生成：openssl rand -base64 32）
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet 加密密钥（生成：docker compose run --rm backend python generate_encryption_key.py）
PLUGIN_API_ENCRYPTION_KEY=your-fernet-key-here

# ==================== 管理员账号 ====================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# ==================== Cookie 配置 ====================
# HTTPS 域名：HTTPS | HTTP IP：HTTP
COOKIE_HTTP=HTTPS

# ==================== Kiro 配置 ====================
KIRO_IDE_VERSION=0.9.2
# KIRO_PROXY_URL=http://host.docker.internal:7890

# ==================== 应用配置 ====================
APP_ENV=production
LOG_LEVEL=INFO
DEBUG_LOG=false
USAGE_LOG_REDACT_HEADERS=true
